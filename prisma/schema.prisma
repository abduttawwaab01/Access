generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model School {
  id           String   @id @default(cuid())
  name         String
  shortName    String?
  slug         String   @unique
  logo         String?
  phone        String?
  email        String?
  address      String?
  motto        String?
  aboutText    String?
  exportDefaultExamHeader String?
  primaryColor String   @default("#6366f1")
  secondaryColor String @default("#06b6d4")
  accentColor  String   @default("#f59e0b")
  settings     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  sessions     AcademicSession[]
  classes      Class[]
  subjects     Subject[]
  students     Student[]
  staff        Staff[]
  announcements Announcement[]
  teacherAssignments TeacherAssignment[]
  lessonNotes        LessonNote[]
  schemeOfWorks      SchemeOfWork[]
  assignments        Assignment[]
  timetableSets      TimetableSet[]
  timetableEntries   TimetableEntry[]
  results            Result[]
  attendanceRecords  AttendanceRecord[]
  fees               Fee[]
  parentLinks        ParentLink[]
  attendanceLogs     AttendanceLog[]
  attendanceQRCodes  AttendanceQRCode[]
  reportCards        ReportCard[]
  topics             Topic[]
  lessonQuizResults  LessonQuizResult[]
  questions          Question[]
  exams              Exam[]
  examSessions       ExamSession[]
  submissions        Submission[]
  bankDetails        BankDetails?
  feeStructures      FeeStructure[]
  payments           Payment[]
  salaryStructures   SalaryStructure[]
  salaryRecords      SalaryRecord[]
  documents          Document[]
  gradingConfigs     GradingConfig?
  admissionSettings  AdmissionSettings?
  admissionApplications AdmissionApplication[]
  entranceExamCodes     EntranceExamCode[]
  events             Event[]
  feedbackTickets    FeedbackTicket[]
  weeklyReports      WeeklyReport[]
  conversations      Conversation[]
  reportCardEntries  ReportCardEntry[]
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(teacher)
  phone     String?
  image     String?
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  students  Student[] @relation("ParentStudent")
  student   Student?  @relation("StudentUser")
  staff     Staff?    @relation("StaffUser")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  audience    String   @default("all")
  priority    String   @default("normal")
  displayType String   @default("banner")
  author      String?
  active      Boolean  @default(true)
  endDate     DateTime?
  source      String   @default("regular")
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  admin
  teacher
  parent
  student
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  terms     Term[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Term {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id        String   @id @default(cuid())
  name      String
  arm       String?
  section   String?
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  subjects  Subject[]
  students  Student[]
  exams     Exam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id       String  @id @default(cuid())
  name     String
  code     String?
  classId  String
  class    Class   @relation(fields: [classId], references: [id])
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id])
  exams    Exam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  studentId     String   @unique
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  phone         String?
  email         String?
  bloodGroup    String?
  medicalNotes  String?
  enrollmentDate DateTime?
  status        String   @default("active")

  passportPhoto String?
  qrCode        String?
  barcode       String?

  classId String
  class   Class @relation(fields: [classId], references: [id])

  parentId String?
  parent   User?  @relation("ParentStudent", fields: [parentId], references: [id])

  userId String? @unique
  user   User?  @relation("StudentUser", fields: [userId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  staffId         String   @unique
  role            String   @default("teacher")
  department      String?
  qualification   String?
  dateOfBirth     DateTime?
  gender          String?
  phone           String?
  email           String?
  address         String?
  employmentDate  DateTime?
  salary          Float?
  passportPhoto   String?
  qrCode          String?
  barcode         String?
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id])

  userId String? @unique
  user   User?   @relation("StaffUser", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeacherAssignment {
  id             String  @id @default(cuid())
  teacherId      String
  classIds       Json    @default("[]")
  subjectIds     Json    @default("[]")
  isClassTeacher Boolean @default(false)
  schoolId       String
  school         School  @relation(fields: [schoolId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([teacherId, schoolId])
}

model LessonNote {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String?
  subject     String?
  title       String
  content     Json?
  topic       String?
  quiz        Json     @default("[]")
  week        Int?
  term        String?
  session     String?
  resources   String?
  status      String   @default("draft")
  createdBy   String?
  approvedBy  String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SchemeOfWork {
  id         String   @id @default(cuid())
  classId    String
  subjectId  String
  title      String
  content    Json?
  status     String   @default("draft")
  createdBy  String?
  approvedBy String?
  approvedAt DateTime?
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Assignment {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String   @default("")
  subject     String?
  type        String?
  title       String
  description String?
  dueDate     DateTime?
  createdBy   String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimetableSet {
  id        String          @id @default(cuid())
  name      String
  type      String?
  classId   String?
  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id])
  entries   TimetableEntry[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model TimetableEntry {
  id          String        @id @default(cuid())
  setId       String?
  set         TimetableSet? @relation(fields: [setId], references: [id], onDelete: Cascade)
  day         String
  period      String?
  startTime   String?
  endTime     String?
  subjectId   String?
  subjectName String?
  classId     String
  teacherId   String?
  teacherName String?
  room        String?
  isBreak     Boolean       @default(false)
  date        String?
  schoolId    String
  school      School        @relation(fields: [schoolId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Result {
  id         String   @id @default(cuid())
  studentId  String
  subjectId  String
  classId    String
  term       String
  session    String?
  examId     String?
  caScore    Float    @default(0)
  examScore  Float    @default(0)
  caTotal    Float?
  examTotal  Float?
  total      Float    @default(0)
  score      Float    @default(0)
  totalMax   Float?
  grade      String   @default("F")
  remark     String   @default("Needs Improvement")
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime
  status    String   @default("present")
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fee {
  id        String   @id @default(cuid())
  studentId String
  amount    Float
  paid      Float    @default(0)
  term      String?
  session   String?
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentLink {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
}

model AttendanceLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  timestamp DateTime @default(now())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
}

model AttendanceQRCode {
  id        String   @id @default(cuid())
  type      String
  data      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
}

model ReportCard {
  id        String   @id @default(cuid())
  studentId String
  data      Json
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReportCardEntry {
  id               String   @id @default(cuid())
  studentId        String
  classId          String
  term             String
  session          String
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id])

  teacherComment   String?
  teacherName      String?
  principalComment String?
  nextTerm         String?
  domains          Json?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, term, session])
}

model Topic {
  id        String   @id @default(cuid())
  name      String
  subjectId String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LessonQuizResult {
  id            String   @id @default(cuid())
  studentId     String
  lessonNoteId  String
  score         Float    @default(0)
  totalQuestions Int     @default(0)
  correctAnswers Int     @default(0)
  answers       Json?
  subject       String?
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  attemptedAt   DateTime @default(now())
}

model Question {
  id         String   @id @default(cuid())
  subjectId  String
  classId    String
  question   String
  type       String   @default("mcq")
  options    Json?
  answer     String?
  difficulty String   @default("medium")
  topic      String?
  points     Int      @default(1)
  approved   Boolean  @default(false)
  approvedBy String?
  approvedAt DateTime?
  createdBy  String?
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Exam {
  id               String   @id @default(cuid())
  title            String
  description      String?
  subjectId        String
  classId          String
  type             String?
  duration         Int?
  shuffleQuestions Boolean  @default(false)
  showResults      Boolean  @default(true)
  requireFullscreen Boolean @default(true)
  tabSwitchLimit   Int      @default(3)
  allowCopyPaste   Boolean  @default(false)
  maxAttempts      Int      @default(0)
  questions        Json     @default("[]")
  status           String   @default("draft")
  approvedBy       String?
  approvedAt       DateTime?
  createdBy        String?
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id])
  class            Class    @relation(fields: [classId], references: [id])
  subject          Subject  @relation(fields: [subjectId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ExamSession {
  id          String    @id @default(cuid())
  examId      String
  examType    String?
  studentId   String
  status      String    @default("pending")
  tabSwitches Int       @default(0)
  flagged     Boolean   @default(false)
  answers     Json?
  score       Float?
  maxScore    Float?
  endTime     DateTime?
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  content      Json?
  fileUrl      String?
  status       String   @default("pending")
  score        Float?
  feedback     String?
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BankDetails {
  id            String   @id @default(cuid())
  schoolId      String   @unique
  school        School   @relation(fields: [schoolId], references: [id])
  bankName      String?
  accountName   String?
  accountNumber String?
  updatedAt     DateTime @updatedAt
}

model FeeStructure {
  id          String   @id @default(cuid())
  classId     String
  type        String   @default("Tuition")
  amount      Float
  dueDate     String?
  description String?
  term        String?
  session     String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  studentId     String
  feeStructureId String?
  amount        Float
  status        String   @default("pending")
  confirmedAt   DateTime?
  confirmedBy   String?
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SalaryStructure {
  id       String  @id @default(cuid())
  staffId  String  @unique
  amount   Float
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id])
  updatedAt DateTime @updatedAt
}

model SalaryRecord {
  id          String   @id @default(cuid())
  staffId     String
  month       String
  year        String
  amount      Float
  status      String   @default("pending")
  paidAt      DateTime?
  confirmedAt DateTime?
  confirmedBy String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([staffId, month, year])
}

model Document {
  id          String   @id @default(cuid())
  studentId   String
  type        String
  content     Json?
  fileUrl     String?
  status      String   @default("final")
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GradingConfig {
  id             String   @id @default(cuid())
  schoolId       String   @unique
  school         School   @relation(fields: [schoolId], references: [id])
  caMax          Float    @default(40)
  examMax        Float    @default(60)
  gradeBoundaries Json    @default("[]")
  updatedAt      DateTime @updatedAt
}

model EntranceExamCode {
  id          String   @id @default(cuid())
  code        String   @unique
  examId      String
  classId     String
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  maxUses     Int      @default(1)
  currentUses Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdmissionSettings {
  id            String   @id @default(cuid())
  schoolId      String   @unique
  school        School   @relation(fields: [schoolId], references: [id])
  cutOffs       Json?
  entranceExamId String?
  updatedAt     DateTime @updatedAt
}

model AdmissionApplication {
  id                  String   @id @default(cuid())
  firstName           String
  lastName            String
  email               String?
  phone               String?
  gender              String?
  dateOfBirth         DateTime?
  address             String?
  classApplyingFor    String?
  parentName          String?
  parentPhone         String?
  previousSchool      String?
  status              String   @default("pending")
  entranceExamPassed  Boolean  @default(false)
  entranceExamScore   Float?
  entranceCodeId      String?
  examSessionId       String?
  adminNotes          String?
  userId              String?
  schoolId            String
  school              School   @relation(fields: [schoolId], references: [id])
  appliedAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String?
  type        String?
  audience    String   @default("all")
  createdBy   String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeedbackTicket {
  id         String   @id @default(cuid())
  from       String
  subject    String
  message    String
  priority   String?
  status     String   @default("pending")
  resolution String?
  resolvedAt DateTime?
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WeeklyReport {
  id          String   @id @default(cuid())
  studentId   String
  classId     String
  week        Int
  term        String?
  session     String?
  content     Json?
  status      String   @default("draft")
  createdBy   String?
  publishedAt DateTime?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Conversation {
  id         String   @id @default(cuid())
  type       String   @default("direct")
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  participants ConversationParticipant[]
  messages    Message[]
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
