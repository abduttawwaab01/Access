generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Level {
  id        String        @id @default(cuid())
  name      String        @unique
  slug      String        @unique
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  classes   Class[]
  schools   SchoolLevel[]

  @@index([sortOrder])
}

model SchoolLevel {
  id        String   @id @default(cuid())
  schoolId  String
  levelId   String
  createdAt DateTime @default(now())
  level     Level    @relation(fields: [levelId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, levelId])
  @@index([schoolId])
}

model School {
  id                      String                 @id @default(cuid())
  name                    String
  shortName               String?
  slug                    String                 @unique
  logo                    String?
  phone                   String?
  email                   String?
  address                 String?
  motto                   String?
  aboutText               String?
  exportDefaultExamHeader String?
  primaryColor            String                 @default("#6366f1")
  secondaryColor          String                 @default("#06b6d4")
  accentColor             String                 @default("#f59e0b")
  settings                Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  sessions                AcademicSession[]
  admissionApplications   AdmissionApplication[]
  admissionSettings       AdmissionSettings?
  announcements           Announcement[]
  assignments             Assignment[]
  attendanceLogs          AttendanceLog[]
  attendanceQRCodes       AttendanceQRCode[]
  attendanceRecords       AttendanceRecord[]
  bankDetails             BankDetails?
  classes                 Class[]
  conversations           Conversation[]
  documents               Document[]
  entranceExamCodes       EntranceExamCode[]
  events                  Event[]
  exams                   Exam[]
  examSessions            ExamSession[]
  fees                    Fee[]
  feeStructures           FeeStructure[]
  feedbackTickets         FeedbackTicket[]
  gradingConfigs          GradingConfig?
  lessonNotes             LessonNote[]
  lessonQuizResults       LessonQuizResult[]
  parentLinks             ParentLink[]
  payments                Payment[]
  questions               Question[]
  reportCards             ReportCard[]
  reportCardEntries       ReportCardEntry[]
  results                 Result[]
  salaryRecords           SalaryRecord[]
  salaryStructures        SalaryStructure[]
  schemeOfWorks           SchemeOfWork[]
  schoolLevels            SchoolLevel[]
  staff                   Staff[]
  students                Student[]
  subjects                Subject[]
  submissions             Submission[]
  teacherAssignments      TeacherAssignment[]
  teacherClasses          TeacherClass[]
  teacherSubjects         TeacherSubject[]
  timetableEntries        TimetableEntry[]
  timetableSets           TimetableSet[]
  topics                  Topic[]
  users                   User[]
  weeklyReports           WeeklyReport[]
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(teacher)
  phone     String?
  image     String?
  schoolId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  staff     Staff?    @relation("StaffUser")
  students  Student[] @relation("ParentStudent")
  student   Student?  @relation("StudentUser")
  school    School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId, role])
}

model Announcement {
  id            String               @id @default(cuid())
  title         String
  content       String
  audience      String               @default("all")
  priority      String               @default("normal")
  displayType   String               @default("banner")
  author        String?
  active        Boolean              @default(true)
  endDate       DateTime?
  source        String               @default("regular")
  buttonLabel   String?
  buttonUrl     String?
  mediaUrl      String?
  mediaType     String?              @default("image")
  reviewEnabled Boolean?             @default(false)
  schoolId      String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  school        School?              @relation(fields: [schoolId], references: [id])
  reviews       AnnouncementReview[]

  @@index([schoolId, audience, active])
}

model AnnouncementReview {
  id             String       @id @default(cuid())
  announcementId String
  userId         String?
  userName       String?
  content        String
  rating         Int?
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id])

  @@index([announcementId])
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  terms     Term[]
}

model Term {
  id        String          @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean         @default(false)
  sessionId String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   AcademicSession @relation(fields: [sessionId], references: [id])
}

model Class {
  id             String         @id @default(cuid())
  name           String
  arm            String?
  section        String?
  schoolId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  levelId        String?
  assignments    Assignment[]
  level          Level?         @relation(fields: [levelId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id])
  exams          Exam[]
  feeStructures  FeeStructure[]
  lessonNotes    LessonNote[]
  questions      Question[]
  results        Result[]
  schemeOfWorks  SchemeOfWork[]
  students       Student[]
  subjects       Subject[]
  teacherClasses TeacherClass[]
  weeklyReports  WeeklyReport[]

  @@index([levelId])
}

model Subject {
  id              String           @id @default(cuid())
  name            String
  code            String?
  classId         String
  schoolId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     Assignment[]
  exams           Exam[]
  lessonNotes     LessonNote[]
  questions       Question[]
  results         Result[]
  schemeOfWorks   SchemeOfWork[]
  class           Class            @relation(fields: [classId], references: [id])
  school          School           @relation(fields: [schoolId], references: [id])
  teacherSubjects TeacherSubject[]
  topics          Topic[]
}

model Student {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  studentId         String             @unique
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  phone             String?
  email             String?
  bloodGroup        String?
  medicalNotes      String?
  enrollmentDate    DateTime?
  status            String             @default("active")
  passportPhoto     String?
  qrCode            String?
  barcode           String?
  classId           String
  parentId          String?
  userId            String             @unique
  schoolId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  documents         Document[]
  examSessions      ExamSession[]
  fees              Fee[]
  lessonQuizResults LessonQuizResult[]
  parentLinks       ParentLink[]
  payments          Payment[]
  reportCards       ReportCard[]
  reportCardEntries ReportCardEntry[]
  results           Result[]
  class             Class              @relation(fields: [classId], references: [id])
  parent            User?              @relation("ParentStudent", fields: [parentId], references: [id])
  school            School             @relation(fields: [schoolId], references: [id])
  user              User               @relation("StudentUser", fields: [userId], references: [id])
  submissions       Submission[]
  weeklyReports     WeeklyReport[]

  @@index([schoolId, classId])
}

model Staff {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  staffId          String           @unique
  role             String           @default("teacher")
  department       String?
  qualification    String?
  dateOfBirth      DateTime?
  gender           String?
  phone            String?
  email            String?
  address          String?
  employmentDate   DateTime?
  salary           Float?
  passportPhoto    String?
  qrCode           String?
  barcode          String?
  schoolId         String
  userId           String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  salaryRecords    SalaryRecord[]
  salaryStructures SalaryStructure?
  school           School           @relation(fields: [schoolId], references: [id])
  user             User?            @relation("StaffUser", fields: [userId], references: [id])
  teacherClasses   TeacherClass[]
  teacherSubjects  TeacherSubject[]

  @@index([schoolId])
}

model TeacherAssignment {
  id             String   @id @default(cuid())
  teacherId      String
  classIds       Json     @default("[]")
  subjectIds     Json     @default("[]")
  isClassTeacher Boolean  @default(false)
  schoolId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  school         School   @relation(fields: [schoolId], references: [id])

  @@unique([teacherId, schoolId])
}

model TeacherClass {
  id             String   @id @default(cuid())
  teacherId      String
  classId        String
  isClassTeacher Boolean  @default(false)
  schoolId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School   @relation(fields: [schoolId], references: [id])
  teacher        Staff    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
  @@index([teacherId])
  @@index([classId])
  @@index([schoolId])
}

model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Staff    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([schoolId])
}

model LessonNote {
  id         String    @id @default(cuid())
  classId    String
  subjectId  String?
  subject    String?
  title      String
  content    Json?
  topic      String?
  quiz       Json      @default("[]")
  week       Int?
  term       String?
  session    String?
  resources  String?
  status     String    @default("draft")
  createdBy  String?
  approvedBy String?
  approvedAt DateTime?
  rejectedAt DateTime?
  schoolId   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  class      Class     @relation(fields: [classId], references: [id])
  school     School    @relation(fields: [schoolId], references: [id])
  subjectRel Subject?  @relation(fields: [subjectId], references: [id])

  @@index([schoolId, classId, subjectId, createdBy])
}

model SchemeOfWork {
  id         String    @id @default(cuid())
  classId    String
  subjectId  String
  title      String
  content    Json?
  status     String    @default("draft")
  createdBy  String?
  approvedBy String?
  approvedAt DateTime?
  schoolId   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  class      Class     @relation(fields: [classId], references: [id])
  school     School    @relation(fields: [schoolId], references: [id])
  subject    Subject   @relation(fields: [subjectId], references: [id])

  @@index([schoolId, classId, subjectId])
}

model Assignment {
  id          String       @id @default(cuid())
  classId     String
  subjectId   String       @default("")
  subject     String?
  type        String?
  title       String
  description String?
  dueDate     DateTime?
  status      String       @default("active")
  createdBy   String?
  schoolId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  class       Class        @relation(fields: [classId], references: [id])
  school      School       @relation(fields: [schoolId], references: [id])
  subjectRel  Subject      @relation(fields: [subjectId], references: [id])
  submissions Submission[]
}

model TimetableSet {
  id        String           @id @default(cuid())
  name      String
  type      String?
  classId   String?
  schoolId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  entries   TimetableEntry[]
  school    School           @relation(fields: [schoolId], references: [id])
}

model TimetableEntry {
  id          String        @id @default(cuid())
  setId       String?
  day         String
  period      String?
  startTime   String?
  endTime     String?
  subjectId   String?
  subjectName String?
  classId     String
  teacherId   String?
  teacherName String?
  room        String?
  isBreak     Boolean       @default(false)
  date        String?
  schoolId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  school      School        @relation(fields: [schoolId], references: [id])
  set         TimetableSet? @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([schoolId, classId, day])
}

model Result {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  classId   String
  term      String
  session   String?
  examId    String?
  caScore   Float    @default(0)
  examScore Float    @default(0)
  caTotal   Float?
  examTotal Float?
  total     Float    @default(0)
  score     Float    @default(0)
  totalMax  Float?
  grade     String   @default("F")
  remark    String   @default("Needs Improvement")
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  exam      Exam?    @relation(fields: [examId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@index([schoolId, studentId, classId, term, session])
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime
  status    String   @default("present")
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([schoolId, studentId, date])
}

model Fee {
  id        String   @id @default(cuid())
  studentId String
  amount    Float
  paid      Float    @default(0)
  term      String?
  session   String?
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId])
}

model ParentLink {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  schoolId  String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, parentId, studentId])
}

model AttendanceLog {
  id        String   @id @default(cuid())
  userId    String
  userType  String?
  date      String
  time      String?
  status    String?
  method    String?
  timestamp DateTime @default(now())
  schoolId  String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, userId, date])
}

model AttendanceQRCode {
  id        String   @id @default(cuid())
  type      String
  data      String
  schoolId  String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
}

model ReportCard {
  id        String   @id @default(cuid())
  studentId String
  data      Json
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId])
}

model ReportCardEntry {
  id               String   @id @default(cuid())
  studentId        String
  classId          String
  term             String
  session          String
  schoolId         String
  teacherComment   String?
  teacherName      String?
  principalComment String?
  nextTerm         String?
  domains          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  school           School   @relation(fields: [schoolId], references: [id])
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, term, session])
  @@index([schoolId, classId, term, session])
}

model Topic {
  id        String   @id @default(cuid())
  name      String
  subjectId String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@index([schoolId, subjectId])
}

model LessonQuizResult {
  id             String   @id @default(cuid())
  studentId      String
  lessonNoteId   String
  score          Float    @default(0)
  totalQuestions Int      @default(0)
  correctAnswers Int      @default(0)
  answers        Json?
  subject        String?
  schoolId       String
  attemptedAt    DateTime @default(now())
  school         School   @relation(fields: [schoolId], references: [id])
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, lessonNoteId])
}

model Question {
  id         String    @id @default(cuid())
  subjectId  String
  classId    String
  question   String
  type       String    @default("mcq")
  options    Json?
  answer     String?
  difficulty String    @default("medium")
  topic      String?
  points     Int       @default(1)
  approved   Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?
  createdBy  String?
  schoolId   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  class      Class     @relation(fields: [classId], references: [id])
  school     School    @relation(fields: [schoolId], references: [id])
  subject    Subject   @relation(fields: [subjectId], references: [id])

  @@index([schoolId, classId, subjectId, approved, difficulty])
}

model Exam {
  id                String        @id @default(cuid())
  title             String
  description       String?
  subjectId         String
  classId           String
  type              String?
  duration          Int?
  shuffleQuestions  Boolean       @default(false)
  showResults       Boolean       @default(true)
  requireFullscreen Boolean       @default(true)
  tabSwitchLimit    Int           @default(3)
  allowCopyPaste    Boolean       @default(false)
  maxAttempts       Int           @default(0)
  questions         Json          @default("[]")
  status            String        @default("draft")
  approvedBy        String?
  approvedAt        DateTime?
  createdBy         String?
  schoolId          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  class             Class         @relation(fields: [classId], references: [id])
  school            School        @relation(fields: [schoolId], references: [id])
  subject           Subject       @relation(fields: [subjectId], references: [id])
  examSessions      ExamSession[]
  results           Result[]

  @@index([schoolId, classId, subjectId, status])
}

model ExamSession {
  id          String    @id @default(cuid())
  examId      String
  examType    String?
  studentId   String
  status      String    @default("pending")
  tabSwitches Int       @default(0)
  flagged     Boolean   @default(false)
  answers     Json?
  score       Float?
  maxScore    Float?
  endTime     DateTime?
  schoolId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  school      School    @relation(fields: [schoolId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, examId, studentId, status])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  content      Json?
  fileUrl      String?
  status       String     @default("pending")
  score        Float?
  feedback     String?
  schoolId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  school       School     @relation(fields: [schoolId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, assignmentId, studentId, status])
}

model BankDetails {
  id            String   @id @default(cuid())
  schoolId      String   @unique
  bankName      String?
  accountName   String?
  accountNumber String?
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id])
}

model FeeStructure {
  id          String   @id @default(cuid())
  classId     String
  type        String   @default("Tuition")
  amount      Float
  dueDate     String?
  description String?
  term        String?
  session     String?
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  class       Class    @relation(fields: [classId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
}

model Payment {
  id             String    @id @default(cuid())
  studentId      String
  feeStructureId String?
  amount         Float
  status         String    @default("pending")
  confirmedAt    DateTime?
  confirmedBy    String?
  schoolId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  school         School    @relation(fields: [schoolId], references: [id])
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, status])
}

model SalaryStructure {
  id        String   @id @default(cuid())
  staffId   String   @unique
  amount    Float
  schoolId  String
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model SalaryRecord {
  id          String    @id @default(cuid())
  staffId     String
  month       String
  year        String
  amount      Float
  status      String    @default("pending")
  paidAt      DateTime?
  confirmedAt DateTime?
  confirmedBy String?
  schoolId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School    @relation(fields: [schoolId], references: [id])
  staff       Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, month, year])
  @@index([schoolId, staffId, month, year])
}

model Document {
  id          String   @id @default(cuid())
  studentId   String
  type        String
  content     Json?
  fileUrl     String?
  status      String   @default("final")
  schoolId    String
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, type])
}

model GradingConfig {
  id              String   @id @default(cuid())
  schoolId        String   @unique
  caMax           Float    @default(40)
  examMax         Float    @default(60)
  gradeBoundaries Json     @default("[]")
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id])
}

model EntranceExamCode {
  id          String    @id @default(cuid())
  code        String    @unique
  examId      String
  classId     String
  schoolId    String
  maxUses     Int       @default(1)
  currentUses Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School    @relation(fields: [schoolId], references: [id])
}

model AdmissionSettings {
  id             String   @id @default(cuid())
  schoolId       String   @unique
  cutOffs        Json?
  entranceExamId String?
  updatedAt      DateTime @updatedAt
  school         School   @relation(fields: [schoolId], references: [id])
}

model AdmissionApplication {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  gender             String?
  dateOfBirth        DateTime?
  address            String?
  classApplyingFor   String?
  parentName         String?
  parentPhone        String?
  previousSchool     String?
  status             String    @default("pending")
  entranceExamPassed Boolean   @default(false)
  entranceExamScore  Float?
  entranceCodeId     String?
  examSessionId      String?
  adminNotes         String?
  userId             String?
  schoolId           String
  appliedAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  school             School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId, status])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String?
  type        String?
  audience    String   @default("all")
  createdBy   String?
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, date, type])
}

model FeedbackTicket {
  id         String    @id @default(cuid())
  from       String
  subject    String
  message    String
  priority   String?
  status     String    @default("pending")
  resolution String?
  resolvedAt DateTime?
  schoolId   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  school     School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId, status])
}

model WeeklyReport {
  id          String    @id @default(cuid())
  studentId   String
  classId     String
  week        Int
  term        String?
  session     String?
  content     Json?
  status      String    @default("draft")
  createdBy   String?
  publishedAt DateTime?
  schoolId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  class       Class     @relation(fields: [classId], references: [id])
  school      School    @relation(fields: [schoolId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, classId, week])
}

model Conversation {
  id           String                    @id @default(cuid())
  type         String                    @default("direct")
  schoolId     String
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  school       School                    @relation(fields: [schoolId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([schoolId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum Role {
  admin
  teacher
  parent
  student
}
